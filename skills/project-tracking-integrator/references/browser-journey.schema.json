{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/project-tracking-integrator/browser-journey.schema.json",
  "title": "Browser tracking verification journey",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "name", "startUrl", "steps", "verification"],
  "properties": {
    "version": { "enum": [1, 2, 3] },
    "name": { "type": "string", "minLength": 1 },
    "startUrl": { "type": "string", "format": "uri", "pattern": "^https?://" },
    "environment": { "enum": ["local", "qa", "production"] },
    "environmentHost": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "ingestionWaitSeconds", "maxQueryAttempts"],
      "properties": {
        "contract": { "type": "string", "minLength": 1 },
        "sinceMinutes": { "type": "integer", "minimum": 1, "maximum": 1440 },
        "ingestionWaitSeconds": { "type": "integer", "minimum": 0, "maximum": 1800 },
        "retryWaitSeconds": { "type": "integer", "minimum": 0, "maximum": 1800 },
        "maxQueryAttempts": { "type": "integer", "minimum": 1, "maximum": 2 },
        "consolePattern": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "maxQueryAttempts": { "const": 2 } },
            "required": ["maxQueryAttempts"]
          },
          "then": {
            "oneOf": [
              {
                "required": ["retryWaitSeconds"],
                "properties": { "retryWaitSeconds": { "minimum": 60 } }
              },
              {
                "not": { "required": ["retryWaitSeconds"] },
                "properties": { "ingestionWaitSeconds": { "minimum": 60 } }
              }
            ]
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "version": { "const": 1 } }, "required": ["version"] },
      "then": { "required": ["environmentHost"] }
    },
    {
      "if": { "properties": { "version": { "const": 2 } }, "required": ["version"] },
      "then": {
        "required": ["environment"],
        "properties": { "verification": { "required": ["sinceMinutes"] } }
      }
    },
    {
      "if": { "properties": { "version": { "const": 1 } }, "required": ["version"] },
      "then": { "properties": { "verification": { "required": ["sinceMinutes"] } } }
    },
    {
      "if": { "properties": { "version": { "const": 3 } }, "required": ["version"] },
      "then": {
        "required": ["environment"],
        "properties": {
          "steps": {
            "items": {
              "allOf": [
                { "$ref": "#/$defs/step" },
                { "required": ["id"] },
                {
                  "if": {
                    "properties": { "action": { "enum": ["click", "hover"] } },
                    "required": ["action"]
                  },
                  "then": { "required": ["expect"] }
                }
              ]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "locator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["testId", "dataAttribute", "href", "role", "label", "placeholder", "text", "css"]
        },
        "value": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "attribute": { "type": "string", "minLength": 1 },
        "exact": { "type": "boolean" },
        "scope": { "$ref": "#/$defs/locator" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "role" } }, "required": ["type"] },
          "then": { "required": ["role", "name"] },
          "else": { "required": ["value"] }
        },
        {
          "if": { "properties": { "type": { "const": "dataAttribute" } }, "required": ["type"] },
          "then": { "required": ["attribute", "value"] }
        },
        {
          "if": { "properties": { "type": { "const": "css" } }, "required": ["type"] },
          "then": {
            "properties": {
              "value": {
                "pattern": "^(?!.*:(?:nth-(?:last-)?(?:child|of-type)\\s*\\(|(?:first|last|only)-(?:child|of-type)\\b|(?:first|last)\\b|eq\\s*\\()).*$"
              }
            }
          }
        }
      ]
    },
    "expectation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "enum": ["visibleText", "visibleElement", "url", "attribute", "selected"] },
        "value": { "type": ["string", "boolean"] },
        "locator": { "$ref": "#/$defs/locator" },
        "attribute": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "enum": ["visibleText", "url"] } }, "required": ["type"] },
          "then": {
            "required": ["value"],
            "properties": { "value": { "type": "string", "minLength": 1 } }
          }
        },
        {
          "if": { "properties": { "type": { "const": "visibleElement" } }, "required": ["type"] },
          "then": {
            "anyOf": [
              { "required": ["locator"] },
              {
                "required": ["value"],
                "properties": { "value": { "type": "string", "minLength": 1 } }
              }
            ]
          }
        },
        {
          "if": { "properties": { "type": { "const": "attribute" } }, "required": ["type"] },
          "then": {
            "required": ["attribute", "value"],
            "properties": { "value": { "type": "string" } }
          }
        },
        {
          "if": { "properties": { "type": { "const": "selected" } }, "required": ["type"] },
          "then": {
            "required": ["value"],
            "properties": { "value": { "type": "boolean" } }
          }
        }
      ]
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "action": { "enum": ["goto", "click", "fill", "select", "press", "hover", "scroll-into-view", "expect-visible", "expect-url"] },
        "url": { "type": "string", "format": "uri", "pattern": "^https?://" },
        "locator": { "$ref": "#/$defs/locator" },
        "value": { "type": "string" },
        "covers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "expect": { "$ref": "#/$defs/expectation" }
      },
      "allOf": [
        {
          "if": { "properties": { "action": { "const": "goto" } }, "required": ["action"] },
          "then": { "required": ["url"] }
        },
        {
          "if": { "properties": { "action": { "enum": ["click", "fill", "select", "press", "hover", "scroll-into-view", "expect-visible"] } }, "required": ["action"] },
          "then": { "required": ["locator"] }
        },
        {
          "if": { "properties": { "action": { "enum": ["fill", "select", "press"] } }, "required": ["action"] },
          "then": { "required": ["value"] }
        },
        {
          "if": { "properties": { "action": { "const": "expect-url" } }, "required": ["action"] },
          "then": { "required": ["value"] }
        }
      ]
    }
  }
}
