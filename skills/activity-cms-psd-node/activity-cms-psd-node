#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

dependencies_ok() {
  [[ -d "$SCRIPT_DIR/node_modules" ]] || return 1
  node --input-type=module -e 'import("ag-psd"); import("@napi-rs/canvas");' >/dev/null 2>&1
}

if ! dependencies_ok; then
  echo "activity-cms-psd-node dependencies are not ready. Running install.sh..." >&2
  "$SCRIPT_DIR/install.sh"
fi

exec node "$SCRIPT_DIR/scripts/create_package.mjs" "$@"
